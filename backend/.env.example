# Server
PORT=3000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=potholesafe
DB_USER=root
DB_PASSWORD=your_password_here

# File Uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# Image Verification
VERIFICATION_MODE=mock
GOOGLE_CLOUD_API_KEY=your_api_key_here
CONFIDENCE_THRESHOLD=0.6

# Session (must be at least 32 characters in production)
SESSION_SECRET=change-this-to-a-random-64-char-string

# CORS — comma-separated allowed origins
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:5501,http://127.0.0.1:5501
